## UniCore .gitignore

# Dependencies
node_modules/
*/node_modules/

# Environment files — NEVER commit these
.env
backend/.env
frontend/.env

# Build outputs
dist/
build/
frontend/dist/

# Uploaded files
backend/uploads/

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# VS Code (keep workspace file, ignore user settings)
.vscode/settings.json
.vscode/launch.json
!UniCore.code-workspace

# Misc
.cache/
.temp/
coverage/
