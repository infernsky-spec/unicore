MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
UNIVERSITY_NAME=EduBridge
AI_ENABLED=true
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
