# ── Required: MongoDB Atlas Connection String ───────────────────────────────
# Get this from: https://cloud.mongodb.com → Clusters → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/edubridge?retryWrites=true&w=majority

# ── Required: JWT Secrets (use long random strings) ────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-string-in-production
JWT_REFRESH_SECRET=change-this-to-another-long-random-secret-string

# ── Server Configuration ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── CORS: Your Vercel frontend URL ─────────────────────────────────────────
CLIENT_URL=https://unicore-ruddy.vercel.app

# ── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=500

# ── Admin Key Settings ──────────────────────────────────────────────────────
ADMIN_KEY_EXPIRY=30d

# ── Auto-seed on first start (set to 'true' to seed on first run) ──────────
AUTO_SEED=true
