PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/unicore
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=change_this_refresh_secret_too
JWT_REFRESH_EXPIRE=30d
